# ----- Vision (pick ONE — Gemini is free) -----
# Google Gemini — FREE: 15 req/min, 1500/day on gemini-2.0-flash.
# Get a key at https://aistudio.google.com/apikey (no credit card).
GEMINI_API_KEY=

# OR — Anthropic Claude (paid, requires credits on console.anthropic.com).
# If both are set, Gemini wins.
# ANTHROPIC_API_KEY=sk-ant-...

# ----- Maps (optional) -----
# By default, Maps mode uses free OpenStreetMap services (Nominatim + OSRM
# + Overpass for bus stops). No key needed. Set this only if you want to
# switch to paid Google Directions for better accuracy.
# GOOGLE_MAPS_API_KEY=AIza...
