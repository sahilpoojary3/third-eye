# ----- Vision (pick ONE — OpenRouter is free and works globally) -----
# OpenRouter — FREE vision via Llama 3.2 11B Vision (or many others).
# Signup via GitHub OAuth, no credit card.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# OR — Google Gemini (free, but geo-restricted in some countries)
# GEMINI_API_KEY=

# OR — Anthropic Claude (paid)
# ANTHROPIC_API_KEY=sk-ant-...

# ----- Maps (optional) -----
# Free OpenStreetMap (Nominatim + OSRM + Overpass) is used by default.
# Set this only to switch to paid Google Directions.
# GOOGLE_MAPS_API_KEY=AIza...
